<Window x:Class="GestionnaireLivres.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GestionnaireLivres.WPF.ViewModels"
        Title="Gestionnaire de Livres — WPF"
        Height="650" Width="1050"
        MinHeight="550" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🔍 Recherche :" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
            <TextBox Width="350" Height="28" FontSize="14" VerticalContentAlignment="Center"
                     Text="{Binding TermeRecherche, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5"
                    Padding="15" Margin="0,0,10,0" Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Text="Détails du livre" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Titre" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Titre, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" FontSize="13" Margin="0,0,0,10"/>

                    <TextBlock Text="Auteur" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Auteur, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" FontSize="13" Margin="0,0,0,10"/>

                    <TextBlock Text="Année" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Annee, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" FontSize="13" Margin="0,0,0,10"/>

                    <TextBlock Text="Genre" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding Genre}"
                              Height="28" FontSize="13" Margin="0,0,0,10"/>

                    <CheckBox Content="Lu ?" IsChecked="{Binding Lu}"
                              FontSize="13" Margin="0,0,0,15"/>

                    <Button Content="Ajouter" Command="{Binding AjouterCommand}"
                            Height="32" FontSize="13"
                            Background="#2E8B57" Foreground="White"
                            Margin="0,0,0,5" Cursor="Hand"/>

                    <Button Content="Modifier" Command="{Binding ModifierCommand}"
                            Height="32" FontSize="13"
                            Background="#4682B4" Foreground="White"
                            Margin="0,0,0,5" Cursor="Hand"/>

                    <Button Content="Supprimer" Command="{Binding SupprimerCommand}"
                            Height="32" FontSize="13"
                            Background="#CD5C5C" Foreground="White"
                            Cursor="Hand"
                            Margin="0,0,0,15"/>

                    <Button Content="Exporter CSV" Command="{Binding ExporterCsvCommand}"
                            Height="32" FontSize="13"
                            Background="#FF8C00" Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding Livres}"
                      SelectedItem="{Binding LivreSelectionne}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="*" />
                    <DataGridTextColumn Header="Auteur" Binding="{Binding Auteur}" Width="*" />
                    <DataGridTextColumn Header="Année" Binding="{Binding Annee}" Width="70" />
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="90" />
                    <DataGridCheckBoxColumn Header="Lu" Binding="{Binding Lu}" Width="50" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2" Background="#2C3E50" CornerRadius="5" Padding="15" Margin="0,10,0,0">
            <TextBlock Foreground="White" FontSize="14" HorizontalAlignment="Center">
                <Run Text="{Binding TotalLivres, StringFormat={}{0} livre(s), Mode=OneWay}" />
                <Run Text="  |  " />
                <Run Text="{Binding LivresLus, StringFormat={}{0} lu(s), Mode=OneWay}" />
                <Run Text="  |  " />
                <Run Text="{Binding PourcentageLus, StringFormat={}{0}% complétés, Mode=OneWay}" />
            </TextBlock>
        </Border>
    </Grid>
</Window>
